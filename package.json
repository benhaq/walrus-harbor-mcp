{
  "name": "walrus-harbor-mcp",
  "version": "0.1.0",
  "description": "MCP server for Walrus Harbor — ggdrive-style decentralized, Seal-encrypted storage on Walrus + Sui",
  "type": "module",
  "bin": {
    "walrus-harbor-mcp": "./bin/harbor-mcp.ts"
  },
  "scripts": {
    "dev": "tsx bin/harbor-mcp.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "effect-language-service patch || true",
    "mcpb:pack": "mcpb pack"
  },
  "keywords": ["mcp", "modelcontextprotocol", "walrus", "harbor", "sui", "seal", "decentralized-storage", "effect"],
  "author": "Commandoss",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@effect/platform": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.9.0",
    "@mysten/seal": "1.1.3",
    "@mysten/sui": "2.17.0",
    "effect": "3.13.7",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@biomejs/biome": "2.4.16",
    "@effect/language-service": "^0.2.0",
    "@types/node": "^22.15.0",
    "esbuild": "^0.25.4",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "peerDependencies": {
    "@mysten/seal": "1.1.3",
    "@mysten/sui": "2.17.0"
  },
  "peerDependenciesMeta": {
    "@mysten/seal": {
      "optional": true
    },
    "@mysten/sui": {
      "optional": true
    }
  }
}
