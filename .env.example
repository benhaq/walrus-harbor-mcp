# Harbor MCP Server Configuration
# Get these values from https://testnet.harbor.walrus.xyz/ → Settings → API Keys

# Required: Your Harbor API key (starts with hbr_)
HARBOR_API_KEY=hbr_your_api_key_here

# Required for create_bucket + upload + download (private Seal-encrypted buckets)
# This is the `suiprivkey1...` service private key shown once when you create the API key.
HARBOR_SERVICE_PRIVATE_KEY=suiprivkey1_your_service_private_key_here

# Optional: Override the API base (defaults to testnet)
# HARBOR_API_BASE_URL=https://api.testnet.harbor.walrus.xyz
