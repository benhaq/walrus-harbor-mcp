src/
bin/
tests/
*.ts
!*.d.ts
tsconfig.json
biome.json
*.config.ts
.env
.env.*
*.mcpb
.git/
.gitignore
.DS_Store
coverage/
pnpm-lock.yaml
README.md

# Local dev / client config (not for distribution)
.claude/
.mcp.json
.env.example
